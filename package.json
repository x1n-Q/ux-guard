{
  "name": "ux-guard-monorepo",
  "private": true,
  "version": "0.1.0",
  "description": "ESLint catches bad code. ux-guard catches unfinished UX. Monorepo root.",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -w ux-guard-core && npm run build -w ux-guard-react && npm run build -w ux-guard && npm run build -w ux-guard-mcp --if-present",
    "clean": "rm -rf packages/*/dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:example": "node packages/cli/dist/index.js scan ./examples/react-sample",
    "test:json": "node packages/cli/dist/index.js scan ./examples/react-sample --json",
    "test:agent": "node packages/cli/dist/index.js scan ./examples/react-sample --json --for-agent",
    "test:report": "node packages/cli/dist/index.js report ./examples/react-sample --markdown",
    "test:next": "node packages/cli/dist/index.js scan ./examples/next-app-router",
    "test:mcp": "node packages/mcp/test-smoke.js"
  },
  "devDependencies": {
    "vitest": "^2.0.5",
    "typescript": "^5.5.4"
  },
  "author": "Daniel Depaor <https://github.com/x1n-Q>",
  "license": "MIT",
  "homepage": "https://github.com/x1n-Q/ux-guard#readme",
  "bugs": {
    "url": "https://github.com/x1n-Q/ux-guard/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/x1n-Q/ux-guard.git"
  },
  "engines": {
    "node": ">=18"
  }
}
